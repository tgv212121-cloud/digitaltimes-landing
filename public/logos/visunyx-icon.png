<style>
/* Додатково блокуємо падінг-скролл у <html> */
html.overflow-hidden {
  overflow: hidden !important;
  height: 100%;
}

.modal-scroll {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch; /* плавний нативний інерційний скрол на iOS */
  overscroll-behavior: contain;      /* ізолює скрол, щоб не “тікав” на body */
  max-height: 100vh;                  /* або ваша висота */
}
  
body.no-scroll {
 overflow: hidden;
}
/* Приховування скролбара сторінки */
html::-webkit-scrollbar { 
 width: 0px !important; 
  -webkit-appearance: none !important;
} 
  
/* Приховування скролбара з певним класом (може бути корисно для елементів з overflow: auto, або scroll) */
.portfolio-modal-window::-webkit-scrollbar {
    display: none !important;
}
