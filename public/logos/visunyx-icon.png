<script>

var Webflow = Webflow || [];

Webflow.push(function () {
  const scrollDisableElements = document.querySelectorAll('[scroll-disable-element]');
  const scrollableElements      = document.querySelectorAll('.modal-scroll');
  let isDisabled = false;

  // Обробник, що відміняє дотики тільки якщо це НЕ в .modal-scroll
  const preventTouch = e => {
    const insideScrollable = Array.from(scrollableElements).some(el => el.contains(e.target));
    if (!insideScrollable) e.preventDefault();
  };

  function disableScroll() {
    const scrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top      = `-${scrollY}px`;
    document.body.style.width    = '100%';
    document.documentElement.classList.add('overflow-hidden');
    document.addEventListener('touchmove', preventTouch, { passive: false });
    isDisabled = true;
  }

  function enableScroll() {
    const top = parseInt(document.body.style.top || '0') * -1;
    document.body.style.position = '';
    document.body.style.top      = '';
    document.body.style.width    = '';
    window.scrollTo(0, top);
    document.documentElement.classList.remove('overflow-hidden');
    document.removeEventListener('touchmove', preventTouch);
    isDisabled = false;
  }

  const observer = new IntersectionObserver(entries => {
    const anyVisible = entries.some(entry => entry.isIntersecting);
    if (anyVisible && !isDisabled) disableScroll();
    if (!anyVisible && isDisabled) enableScroll();
  });

  scrollDisableElements.forEach(el => observer.observe(el));
});

</script></body></html>